# ─────────────────────────────────────────────────────────────────────────────
# QR Generator SaaS — Environment Variables
# Copy this file to .env.local and fill in the values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Full URL of the deployment (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: custom domain used for QR tracking redirects (e.g. https://go.yourdomain.com)
# If omitted, NEXT_PUBLIC_BASE_URL is used.
NEXT_PUBLIC_TRACKING_URL=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service role key — bypasses RLS, NEVER expose to the browser
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SECRET_KEY=<service-role-key>

# ── LemonSqueezy (Payments) ───────────────────────────────────────────────────
# Found in: LemonSqueezy Dashboard → Settings → API
LEMONSQUEEZY_API_KEY=<api-key>

# Found in: LemonSqueezy Dashboard → Stores
LEMONSQUEEZY_STORE_ID=<store-id>

# Generated when creating a webhook in LemonSqueezy Dashboard
LEMONSQUEEZY_WEBHOOK_SECRET=<webhook-signing-secret>

# Variant IDs for each plan (LemonSqueezy Dashboard → Products → Variants)
NEXT_PUBLIC_LS_PRO_VARIANT_ID=<pro-monthly-variant-id>
NEXT_PUBLIC_LS_PRO_ANNUAL_VARIANT_ID=<pro-annual-variant-id>
NEXT_PUBLIC_LS_BUSINESS_VARIANT_ID=<business-monthly-variant-id>
NEXT_PUBLIC_LS_BUSINESS_ANNUAL_VARIANT_ID=<business-annual-variant-id>

# ── Geolocation (optional) ────────────────────────────────────────────────────
# Used to resolve country/region/city from scan IP addresses.
# Get a free token at https://ipinfo.io
# If omitted, geolocation is skipped and analytics will show "Unknown" locations.
IPINFO_TOKEN=
